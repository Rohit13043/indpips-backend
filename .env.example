# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Database ----
# Dev default: zero-config SQLite. For production swap to Postgres, e.g.:
# DATABASE_URL="postgresql://user:pass@localhost:5432/propfirm?schema=public"
# (and change the provider in prisma/schema.prisma from "sqlite" to "postgresql")
DATABASE_URL="file:./dev.db"

# ---- Auth ----
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---- MT5 data source ----
# Which adapter the sync worker uses: mock | metaapi | eabridge
MT5_ADAPTER="mock"

# MetaApi (https://metaapi.cloud) — only needed if MT5_ADAPTER=metaapi
METAAPI_TOKEN=""
METAAPI_REGION="new-york"

# EA bridge shared secret — only needed if MT5_ADAPTER=eabridge
# The MT5 Expert Advisor includes this secret when POSTing trades to /ingest
EA_BRIDGE_SECRET="change-me"

# ---- Sync worker ----
SYNC_INTERVAL_MS=60000
